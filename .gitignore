# Build directories (root-anchored — macOS APFS is case-insensitive, so
# unanchored `build/` would swallow source paths like include/topo/Build/,
# lib/Build/, test/build/ during `git add -A`)
/build/
/out/
/cmake-build-*/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
*.cmake.gen

# Compiled objects
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

# Editor / IDE
.vscode/
.idea/
.vs/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# topo-check cache — CheckRunner writes it into the project dir it runs
# on. Tests copy fixtures to a temp dir first; this covers manual runs
# against the source-tree fixtures.
.topo-check-cache

# Python (test scratch only)
__pycache__/
*.pyc

# vcpkg
vcpkg_installed/
