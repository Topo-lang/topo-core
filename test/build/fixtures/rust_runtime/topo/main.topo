// 27_rust_runtime — Rust with parallel runtime
// Skeleton: verifies Rust build with parallel feature enabled

using i32 = std::rust::i32;

namespace compute {
  public:
    i32 transform(i32 input);

    fn transform {
      step_a -> step_b;
      step_b -> i32;
    }

  protected:
    i32 step_a(i32 x);
    i32 step_b(i32 x);
}
