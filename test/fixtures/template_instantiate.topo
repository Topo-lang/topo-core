// Test fixture for template instantiation verification

using Int = std::cpp17::int;
using Double = std::cpp17::double;

namespace container {

  public:
    template<typename T>
    class Vector {
        public:
            void push_back(T value);
            T get(Int index);
    }

    template<typename K, typename V>
    class Map {
        public:
            void insert(K key, V value);
    }

    template<typename T>
    T identity(T value);

    instantiate Vector<Int>;
    instantiate identity<Int>;
    instantiate Map<Int, Double>;
}
